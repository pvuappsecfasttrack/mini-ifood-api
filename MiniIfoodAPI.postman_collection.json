            "description": "Buscar produto específico por ID (também usa cache)"
          },
          "response": []
        },
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log('⚠️ CREATE: Cache será LIMPA (CacheEvict)');",
                  "console.log('Próxima requisição de GET vai refazer o cache!');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{auth_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Novo Produto\",\n  \"description\": \"Descrição do novo produto\",\n  \"price\": 29.99,\n  \"quantityAvailable\": 100\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/products",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "products"
              ]
            },
            "description": "Criar novo produto (LIMPA TODO CACHE com @CacheEvict)"
          },
          "response": []
        },
